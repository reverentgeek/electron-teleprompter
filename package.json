{
	"name": "electron-teleprompter",
	"productName": "Electron Teleprompter",
	"version": "4.0.10",
	"description": "Desktop teleprompter application ",
	"main": "src/main.js",
	"type": "module",
	"scripts": {
		"build:editor": "esbuild src/client/editor.js --bundle --format=iife --global-name=EditorModule --outfile=src/client/editor-bundle.js",
		"prestart": "pnpm build:editor",
		"start": "electron .",
		"prebuild": "pnpm build:editor",
		"build": "pnpm dlx @electron/packager --overwrite ./ --out ./dist --ignore=\"/node_modules/\\.ignored\" --ignore=\"/node_modules/(electron|@electron|eslint)\"",
		"lint": "eslint --fix"
	},
	"author": "David Neal <david@reverentgeek.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/reverentgeek/electron-teleprompter.git"
	},
	"engines": {
		"node": ">=22.16.0"
	},
	"devDependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@electron/packager": "^20.0.1",
		"codemirror": "^6.0.2",
		"electron": "^42.4.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.1",
		"eslint-config-reverentgeek": "^7.1.9"
	},
	"dependencies": {
		"chokidar": "^5.0.0",
		"showdown": "^2.1.0"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
